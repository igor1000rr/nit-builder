# ─── LLM Providers (choose at least one) ────────────────

# LM Studio — local, free, private (recommended for RTX 3060+)
# Download: https://lmstudio.ai
# Recommended model: Qwen2.5-Coder-7B-Instruct (Q4_K_M)
LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_MODEL=qwen2.5-coder-7b-instruct

# Groq — cloud, free tier, fast (fallback for users without GPU)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — paid, access to 200+ models (optional)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-2.5-coder-32b-instruct

# ─── Auth (optional) ────────────────────────────────────

# Set to enable auth — required in production.
# Leave empty for public dev mode.
NIT_API_SECRET=

# Daily limit for guests (anonymous users) per IP
GUEST_DAILY_LIMIT=10

# ─── App ────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Feedback loop (опц.) ────────────────────────────────
#
# Append-only JSONL с метаданными каждой генерации (query → plan → outcome).
# Используется для анализа неудачных запросов, фьючерных LoRA fine-tunes,
# и накопления корпуса для few-shot examples.
#
# По умолчанию выключено. Для production рекомендуется:
#   NIT_FEEDBACK_ENABLED=1
#   NIT_FEEDBACK_LOG_PATH=/var/lib/nit/feedback.jsonl
#
# /tmp/nit-feedback.jsonl (default) ТЕРЯЕТСЯ при reboot VPS — не использовать в проде.
NIT_FEEDBACK_ENABLED=0
# NIT_FEEDBACK_LOG_PATH=/var/lib/nit/feedback.jsonl

# ─── Trust proxy (production обязательно) ──────────────────
#
# Comma-separated список IP с которых сервер ДОВЕРЯЕТ заголовкам
# X-Forwarded-For / X-Real-IP / CF-Connecting-IP. Без этого атакующий
# может подделкой заголовка сбрасывать rate-limit и guest quota.
#
# Обычно — IP вашего nginx (127.0.0.1 если на том же сервере).
# TRUSTED_PROXY_IPS=127.0.0.1,::1

# ─── Admin endpoints (опц.) ─────────────────────────────
#
# Защищает /api/admin/* (eval, metrics, RAG, guest-limits cleanup).
# Если не задан — admin-эндпоинты возвращают 503 (fail-secure).
# Минимум 8 символов.
# NIT_ADMIN_TOKEN=

# ─── Auth (production обязательно) ──────────────────────
#
# HMAC ключ для подписи session cookie И для tunnel-token lookup.
# Минимум 32 символа. Меняй редко — смена выкидывает всех юзеров.
# Сгенерировать: openssl rand -hex 32
# NIT_TOKEN_LOOKUP_SECRET=

# ─── Appwrite (production) ──────────────────────────────
#
# Backend для multi-user auth и "Мои сайты". Без API_KEY auth работает в
# одно-пользовательском режиме через NIT_API_SECRET.
# APPWRITE_API_KEY=
# APPWRITE_ENDPOINT=https://appwrite.vibecoding.by/v1
# APPWRITE_PROJECT_ID=69ab07130011752aae12
# APPWRITE_DATABASE_ID=nit_builder

# ─── Tunnel (dev) ───────────────────────────────────────
#
# Токен для локального туннель-клиента когда Appwrite не настроен.
# В production не используется (юзеры получают real tunnel-token при register).
# NIT_DEV_TUNNEL_TOKEN=
