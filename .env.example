# ─── LLM Providers (choose at least one) ────────────────

# LM Studio — local, free, private (recommended for RTX 3060+)
# Download: https://lmstudio.ai
# Recommended model: Qwen2.5-Coder-7B-Instruct (Q4_K_M)
LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_MODEL=qwen2.5-coder-7b-instruct

# Groq — cloud, free tier, fast (fallback for users without GPU)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — paid, access to 200+ models (optional)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-2.5-coder-32b-instruct

# ─── Auth (optional) ────────────────────────────────────

# Set to enable auth — required in production.
# Leave empty for public dev mode.
NIT_API_SECRET=

# Daily limit for guests (anonymous users) per IP
GUEST_DAILY_LIMIT=10

# ─── App ────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
LOG_LEVEL=info
