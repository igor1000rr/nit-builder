{
  "name": "nit-builder",
  "version": "2.0.0-beta.1",
  "description": "AI HTML site builder with peer-to-peer tunnel architecture. Users bring their own GPU.",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "homepage": "https://github.com/igor1000rr/nit-builder",
  "repository": {
    "type": "git",
    "url": "https://github.com/igor1000rr/nit-builder.git"
  },
  "workspaces": [
    "shared",
    "tunnel",
    "tunnel/desktop/ui"
  ],
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "tsx server.ts",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "format": "prettier --write 'app/**/*.{ts,tsx,css}'",
    "tunnel:dev": "npm run dev --workspace tunnel",
    "tunnel:build": "npm run build --workspace tunnel",
    "shared:build": "npm run build --workspace shared",
    "migrate:appwrite": "tsx scripts/appwrite-migrate.ts",
    "eval": "tsx scripts/runEval.ts",
    "eval:nightly": "tsx scripts/runEval.ts --label=nightly --compare-last --fail-on-regression",
    "eval:trend": "tsx scripts/evalTrend.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.102",
    "@react-router/node": "^7.0.0",
    "ai": "^5.0.167",
    "argon2": "^0.44.0",
    "isbot": "^5.1.0",
    "node-appwrite": "^14.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "tsx": "^4.21.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@react-router/dev": "^7.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.12",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.4.2",
    "vite-tsconfig-paths": "^5.1.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
