{
  "name": "nit-builder",
  "version": "1.0.0",
  "description": "AI HTML site builder for local LLMs. Create websites on your own computer via LM Studio.",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "homepage": "https://github.com/igor1000rr/nit-builder",
  "repository": {
    "type": "git",
    "url": "https://github.com/igor1000rr/nit-builder.git"
  },
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write 'app/**/*.{ts,tsx,css}'"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.0.0",
    "@react-router/node": "^7.0.0",
    "@react-router/serve": "^7.0.0",
    "ai": "^4.0.0",
    "isbot": "^5.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@react-router/dev": "^7.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prettier": "^3.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.1.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
