{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "main-capability",
  "description": "Main window capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:event:default",
    "shell:allow-open",
    "store:default",
    "updater:default",
    "autostart:default"
  ]
}
