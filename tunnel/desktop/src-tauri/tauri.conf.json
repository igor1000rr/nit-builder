{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NIT Tunnel",
  "version": "0.1.0-alpha",
  "identifier": "by.vibecoding.nit-tunnel",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build:ui",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NIT Tunnel",
        "width": 480,
        "height": 640,
        "minWidth": 400,
        "minHeight": 500,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: https://nit.vibecoding.by wss://nit.vibecoding.by http://localhost:* ws://localhost:*; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "NIT Tunnel"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright © 2026 Igor",
    "category": "DeveloperTool",
    "shortDescription": "NIT Builder tunnel client",
    "longDescription": "Proxy your LM Studio to NIT Builder sites so you can generate HTML pages using your own GPU.",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "exceptionDomain": "localhost"
    },
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://nit.vibecoding.by/downloads/latest.json"
      ],
      "dialog": true
    },
    "autostart": {
      "activated": true
    }
  }
}
